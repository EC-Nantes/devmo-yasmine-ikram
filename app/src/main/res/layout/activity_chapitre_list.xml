<?xml version="1.0" encoding="utf-8"?>
<!-- res/layout/activity_chapitre_list.xml -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- Header : bouton retour + titre -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingHorizontal="16dp">

        <ImageView
            android:id="@+id/btnRetour"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_centerVertical="true"
            android:src="@android:drawable/ic_media_previous"
            android:contentDescription="Retour" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Titre du livre"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="#000000" />
    </RelativeLayout>

    <!-- Barre de progression -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingBottom="12dp"
        android:gravity="center_vertical">

        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="0dp"
            android:layout_height="6dp"
            android:layout_weight="1"
            android:max="100"
            android:progress="5"
            android:progressTint="#2196F3" />

        <TextView
            android:id="@+id/tvPourcentage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="5%"
            android:textSize="12sp"
            android:textColor="#666666"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <!-- Titre (caché, utilisé dans le code) -->
    <TextView
        android:id="@+id/tvTitreLivre"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="gone" />

    <!-- Liste des chapitres -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewChapitres"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>