<?xml version="1.0" encoding="utf-8"?>
<!-- res/layout/item_chapitre.xml -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- Ligne principale -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvChapitreTitre"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chapitre 1"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#000000" />

            <TextView
                android:id="@+id/tvChapitreProgression"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3%"
                android:textSize="12sp"
                android:textColor="#888888"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Icône statut -->
        <ImageView
            android:id="@+id/ivStatutChapitre"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginEnd="10dp"
            android:src="@android:drawable/checkbox_off_background"
            android:contentDescription="Statut" />

        <!-- Chevron droite ou bas -->
        <ImageView
            android:id="@+id/ivChevron"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@android:drawable/ic_media_next"
            android:contentDescription="Déplier" />
    </LinearLayout>

    <!-- Sous-menu dépliable -->
    <LinearLayout
        android:id="@+id/layoutSousMenu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:background="#F8F8F8">

        <!-- Playlist recommandées -->
        <LinearLayout
            android:id="@+id/layoutPlaylist"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="24dp"
            android:paddingEnd="16dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_media_play"
                android:layout_marginEnd="12dp"
                android:contentDescription="Playlist" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Playlist recommandées"
                android:textSize="14sp"
                android:textColor="#333333" />
        </LinearLayout>

        <!-- Séparateur -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginStart="24dp" />

        <!-- Commentaires -->
        <LinearLayout
            android:id="@+id/layoutCommentaires"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="24dp"
            android:paddingEnd="16dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/sym_action_chat"
                android:layout_marginEnd="12dp"
                android:contentDescription="Commentaires" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Commentaires"
                android:textSize="14sp"
                android:textColor="#333333" />
        </LinearLayout>
    </LinearLayout>

    <!-- Séparateur bas -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0" />

</LinearLayout>